generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique @db.VarChar(255)
  password String
  token    Token?
}

model Token {
  id     Int    @id @default(autoincrement())
  userId Int    @unique
  token  String @unique @db.VarChar(500)

  user User @relation(fields: [userId], references: [id])
}

model CarModels {
  id                Int         @id @default(autoincrement())
  modelSeries       ModelSeries
  modelName         String      @db.VarChar(255)
  modelAcceleration String      @db.VarChar(64)
  topSpeed          String      @db.VarChar(64)
  fuelType          String      @db.VarChar(64)
  powerKwKp         String      @db.VarChar(64)
  modelImage        String      @db.VarChar(64)
}

enum ModelSeries {
  SERIES_911
  SERIES_718
}
