generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique @db.VarChar(255)
  password String

  token  Token?
  config UserConfig[]
}

model Token {
  id     Int    @id @default(autoincrement())
  userId Int    @unique
  token  String @unique @db.VarChar(500)

  user User @relation(fields: [userId], references: [id])
}

model CarModels {
  id                Int         @id @default(autoincrement())
  modelSeries       ModelSeries
  modelName         String      @db.VarChar(255)
  modelAcceleration String      @db.VarChar(64)
  topSpeed          String      @db.VarChar(64)
  fuelType          String      @db.VarChar(64)
  powerKwKp         String      @db.VarChar(64)
  modelImage        String      @db.VarChar(64)

  modelDetail ModelDetail?
  UserConfig  UserConfig[]
}

enum ModelSeries {
  SERIES_911
  SERIES_718
}

model ModelDetail {
  id            Int      @id @default(autoincrement())
  carModelId    Int      @unique
  price         Int
  previewImages String[]

  carModel CarModels @relation(fields: [carModelId], references: [id])
}

model UserConfig {
  id      Int @id @default(autoincrement())
  userId  Int
  modelId Int

  exterior Json
  wheels   Json
  interior Json
  package  Json
  exhaust  Json

  configPrice Int
  totalPrice  Int

  configHash String @unique

  user  User      @relation(fields: [userId], references: [id])
  model CarModels @relation(fields: [modelId], references: [id])
}
